# FinTrack Environment Variables
# Copy this file to .env and fill in your values.
# All EXPO_PUBLIC_ vars are bundled into the client app.

# ─── Firebase (Firestore) ─────────────────────────────────────────────────────
# Get these from Firebase Console → Project Settings → Your apps → SDK setup
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id

# ─── Cerebras AI Inference ────────────────────────────────────────────────────
# Get your key at: https://cloud.cerebras.ai → API Keys
EXPO_PUBLIC_CEREBRAS_API_KEY=your_cerebras_api_key_here

# ─── OpenAI Whisper (Speech-to-Text) ─────────────────────────────────────────
# Get your key at: https://platform.openai.com → API Keys
# Used only for voice input transcription
EXPO_PUBLIC_OPENAI_API_KEY=your_openai_api_key_here
